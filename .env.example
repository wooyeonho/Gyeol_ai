# =============================================================================
# GYEOL (결) - Environment Variables Configuration
# =============================================================================
# 이 파일을 .env.local (로컬) 또는 Vercel/Supabase 대시보드에 복사하여 사용하세요.

# -----------------------------------------------------------------------------
# 1. SUPABASE (필수 - 웹앱 + Edge Functions)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# 2. AI PROVIDERS (필수 - GROQ가 주력, DeepSeek/Gemini는 폴백)
# -----------------------------------------------------------------------------
# GROQ - 메인 AI 두뇌 (반드시 설정)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek - 폴백 AI #1 (선택, 권장)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gemini - 폴백 AI #2 (선택, 권장)
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# 3. CLOUDFLARE WORKERS AI (벡터 임베딩 - 무료)
# -----------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# 4. BYOK 암호화 (필수 - 32자 이상 랜덤 문자열)
# -----------------------------------------------------------------------------
# 예: openssl rand -base64 32
ENCRYPTION_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# 5. OPENCLAW (Koyeb) - 자율 에이전트 엔진
# -----------------------------------------------------------------------------
# Koyeb 서버 주소 (예: https://gyeol-openclaw.koyeb.app)
OPENCLAW_GATEWAY_URL=http://localhost:8080

# Koyeb 서버 인증 토큰 (선택)
OPENCLAW_GATEWAY_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# 6. KILL SWITCH (관리자용 - 선택)
# -----------------------------------------------------------------------------
# 서비스 긴급 정지용 토큰
KILL_SWITCH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# 7. 사이트 URL (선택 - OG 태그 등)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# 8. TELEGRAM (선택 - 텔레그램 봇 연동)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# -----------------------------------------------------------------------------
# 9. STRIPE (선택 - 결제)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Stripe Dashboard에서 Product/Price 생성 후 ID 입력
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# 10. NODE ENV (자동 설정)
# -----------------------------------------------------------------------------
NODE_ENV=development
